# Optional — jury demo works WITHOUT this file (uses embedded DEMO_TRACE).
#
# Vite reads these at BUILD time only (VITE_* prefix). For production:
#   → set the same keys in Vercel / Netlify / Cloudflare "Environment Variables"
#   → then run: pnpm web:build
#
# Local dev: copy to .env.local (gitignored):
#   cp .env.example .env.local

# --- Testnet interactive app (native XLM SAC — best for jury wallet testing) ---
# Walrus-backed round creation requires a contract deployed from the current
# WASM, including attach_storage_ref/get_storage_ref. Older contract IDs can
# still create ordinary rounds but cannot bind a Bosphor/Walrus receipt on-chain.
VITE_RPC_URL=https://soroban-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_CONTRACT_ID=CC2QMOXZERI6UOR67YKSORT7QTUHQ5QUGMHQBYVP23YM3NMUNNOEOGZY
VITE_ESCROW_TOKEN_LABEL=XLM

# --- Testnet USDC lifecycle proof contract (agents:e2e recorded trace) ---
# VITE_CONTRACT_ID=CAPTODBCDEVIK23ALBJBS2TXRTIK47ZA5MBTHYF4XLHG2BK7JPYUCU2Y
# VITE_ROUND_ID=1

# --- Mainnet live poll (optional) ---
# VITE_RPC_URL=https://rpc.ankr.com/stellar_soroban
# VITE_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015
# VITE_CONTRACT_ID=CA7KSDEYJEPGZEB2ZROTLUWKQQ6GIRIQNGG6Z745MZ34QHP4UJPWODEX
# VITE_ROUND_ID=1

# --- Passkey-Kit wallet demo (optional) ---
# Default testnet WASM is baked in for localhost; override if you redeploy passkey-kit contracts.
# VITE_PASSKEY_WALLET_WASM_HASH=ecd990f0b45ca6817149b6175f79b32efb442f35731985a084131e8265c4cd90
# VITE_PASSKEY_RP_ID=localhost

# --- Bosphor/Walrus storage layer extension ---
# Freighter route uses VITE_WALRUS_PUBLISHER_URL for direct encrypted Walrus storage.
# RainbowKit route uses Bosphor for EVM-to-Walrus storage intents.
VITE_STORAGE_MODE=bosphor
VITE_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
VITE_BOSPHOR_ADAPTER_ADDRESS=0xbC7EF2F021F517d871282C2bb512C741ad2958c3
VITE_BOSPHOR_CHAIN_ID=11155111
VITE_BOSPHOR_DST_EID=40378
VITE_BOSPHOR_LZ_OPTIONS=0x00030100110100000000000000000000000000030d40
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: use a custom Sepolia RPC for Bosphor reads.
# VITE_EVM_RPC_URL=

# --- GOAT agent page ---
# Points the browser to services/appraisal-api. POST /goat/agent-decision is
# x402-gated; the plain browser fetch intentionally receives HTTP 402 unless a
# paid agent client signs and retries.
VITE_GOAT_AGENT_API_URL=http://127.0.0.1:4021

# Demo-only paid browser flow. This secret must be a funded Stellar testnet payer
# with the USDC trustline/balance required by the backend's x402 asset. Do not
# put a production or valuable wallet secret in a public frontend build.
# VITE_GOAT_PAYER_SECRET=S...
# VITE_GOAT_RPC_URL=https://soroban-testnet.stellar.org
